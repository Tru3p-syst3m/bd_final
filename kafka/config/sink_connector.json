{
  "name": "postgres-sink-connector",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://postgres:5432/shopdb",
    "connection.user": "postgres",
    "connection.password": "postgres",
    "topics": "orders-events",
    "tasks.max": "1",
    "auto.create": "false",
    "insert.mode": "upsert",
    "pk.mode": "record_key",
    "pk.fields": "eventId",
    "table.name.format": "orders",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",
    "fields.whitelist": "eventId,eventType,entityId,timestamp,source,version,payload.orderId,payload.customerId,payload.amount,payload.currency,payload.status"
  }
}